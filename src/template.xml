<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>

<html
    b:css='false'
    b:defaultwidgetversion='2'
    b:layoutsVersion='3'
    b:responsive='true'
    expr:dir='data:blog.languageDirection'
    expr:lang='data:blog.locale'
    xmlns='http://www.w3.org/1999/xhtml'
    xmlns:b='http://www.google.com/2005/gml/b'
    xmlns:data='http://www.google.com/2005/gml/data'
    xmlns:expr='http://www.google.com/2005/gml/expr'>

<head>

    <meta charset='UTF-8'/>
    <meta content='width=device-width, initial-scale=1' name='viewport'/>

    <title>
        <data:view.title/>
    </title>

    <b:skin><![CDATA[

{{KS_CSS}}

    ]]></b:skin>

</head>

<body>

<div class='ks-wrapper'>

    <!-- =====================================================
         Header
    ====================================================== -->

    <header class='ks-header'>

        <div class='ks-container ks-header-container'>

            <a class='ks-logo' expr:href='data:blog.homepageUrl'>

                <img alt='Logo' src=''/>

                <span class='ks-logo-text'>
                    KeiScanlation
                </span>

            </a>

            <nav class='ks-nav'>

                <ul class='ks-nav-list'>

                    <li>
                        <a class='ks-nav-link' expr:href='data:blog.homepageUrl'>
                            Beranda
                        </a>
                    </li>

                    <li>
                        <a class='ks-nav-link' href='#'>
                            Daftar Novel
                        </a>
                    </li>

                    <li>
                        <a class='ks-nav-link' href='#'>
                            Genre
                        </a>
                    </li>

                    <li>
                        <a class='ks-nav-link' href='#'>
                            Completed
                        </a>
                    </li>

                </ul>

            </nav>

            <div class='ks-header-action'>

                <button class='ks-icon-btn ks-darkmode' type='button' aria-label='Dark Mode'>
                    🌙
                </button>

                <button class='ks-icon-btn ks-search' type='button' aria-label='Search'>
                    🔍
                </button>

                <button class='ks-icon-btn ks-menu-toggle' type='button' aria-label='Menu'>
                    ☰
                </button>

            </div>

        </div>

    </header>

    <!-- =====================================================
         Main
    ====================================================== -->
<!-- =====================================================
     Main
===================================================== -->

<main class='ks-main'>

    <div class='ks-container'>

        <!-- =====================================================
             Homepage
        ====================================================== -->

        <b:if cond='data:view.isHomepage'>

            <div class='ks-page'>

                <div class='ks-layout'>

                    <!-- =====================================
                         Content
                    ====================================== -->

                    <section class='ks-content'>

                        <!-- Hero -->

                        <section class='ks-hero'>

                            <div class='ks-hero-inner'>

                                <h1 class='ks-hero-title'>
                                    KeiScanlation
                                </h1>

                                <p class='ks-hero-description'>
                                    Tempat membaca terjemahan Light Novel bahasa Indonesia.
                                </p>

                            </div>

                        </section>

                        <!-- Latest Update -->

                        <section class='ks-home-section'>

                            <div class='ks-section-header'>

                                <h2 class='ks-section-title'>
                                    Update Terbaru
                                </h2>

                            </div>

                            <div class='ks-novel-grid'>

                                <!-- Novel Card -->

                                <article class='ks-card'>

                                    <a class='ks-card-cover' href='#'>

                                        <img alt='Novel Cover' src=''/>

                                    </a>

                                    <div class='ks-card-body'>

                                        <h3 class='ks-card-title'>

                                            <a href='#'>
                                                Judul Novel
                                            </a>

                                        </h3>

                                        <div class='ks-card-meta'>

                                            <span>Chapter 1</span>

                                            <span class='ks-badge'>
                                                Ongoing
                                            </span>

                                        </div>

                                    </div>

                                </article>

                            </div>

                        </section>

                        <!-- Pagination -->

                        <nav class='ks-pagination'>

                            <a class='ks-page-link is-active' href='#'>
                                1
                            </a>

                            <a class='ks-page-link' href='#'>
                                2
                            </a>

                            <a class='ks-page-link' href='#'>
                                3
                            </a>

                        </nav>

                    </section>

                    <!-- =====================================
                         Sidebar
                    ====================================== -->

                    <aside class='ks-sidebar'>

                        <div class='ks-widget'>

                            <h3 class='ks-widget-title'>
                                Continue Reading
                            </h3>

                            <div class='ks-widget-body'>

                            </div>

                        </div>

                        <div class='ks-widget'>

                            <h3 class='ks-widget-title'>
                                Popular Novel
                            </h3>

                            <div class='ks-widget-body'>

                            </div>

                        </div>

                        <div class='ks-widget'>

                            <h3 class='ks-widget-title'>
                                Genre
                            </h3>

                            <div class='ks-widget-body'>

                            </div>

                        </div>

                        <div class='ks-widget'>

                            <h3 class='ks-widget-title'>
                                Completed
                            </h3>

                            <div class='ks-widget-body'>

                            </div>

                        </div>

                    </aside>

                </div>

            </div>

        </b:if>

        <!-- =====================================================
             Post
        ====================================================== -->

        <b:if cond='data:view.isPost'>

            <div class='ks-page'>

                <section class='ks-content'>

                    <nav class='ks-breadcrumb'>

                        <a expr:href='data:blog.homepageUrl'>
                            Beranda
                        </a>

                        <span>/</span>

                        <span>Novel</span>

                    </nav>

                    <header class='ks-post-header'>

                        <h1 class='ks-post-title'>
                            Judul Chapter
                        </h1>

                        <p class='ks-post-subtitle'>
                            Volume 1
                        </p>

                        <div class='ks-post-meta'>

                            <span>Penulis</span>

                            <span>•</span>

                            <span>Chapter 1</span>

                        </div>

                    </header>

                    <div class='ks-reader'>

                        <article class='ks-reader-content'>

                            <!-- Chapter Content -->

                        </article>

                    </div>

                    <nav class='ks-chapter-nav'>

                        <a class='ks-chapter-btn' href='#'>
                            ← Sebelumnya
                        </a>

                        <a class='ks-chapter-btn' href='#'>
                            Daftar Bab
                        </a>

                        <a class='ks-chapter-btn' href='#'>
                            Selanjutnya →
                        </a>

                    </nav>

                    <section class='ks-related'>

                    </section>

                    <section class='ks-comment'>

                    </section>

                </section>

            </div>

        </b:if>

        <!-- =====================================================
             Static Page
        ====================================================== -->

        <b:if cond='data:view.isPage'>

            <div class='ks-page'>

                <section class='ks-content'>

                    <h1 class='ks-post-title'>
                        Halaman
                    </h1>

                </section>

            </div>

        </b:if>

        <!-- =====================================================
             Search
        ====================================================== -->

        <b:if cond='data:view.isSearch'>

            <div class='ks-page'>

                <section class='ks-content'>

                    <!-- Search Result -->

                </section>

            </div>

        </b:if>

        <!-- =====================================================
             Error 404
        ====================================================== -->

        <b:if cond='data:view.isError'>

            <div class='ks-page'>

                <section class='ks-content ks-text-center'>

                    <h1 class='ks-post-title'>
                        404
                    </h1>

                    <p>
                        Halaman tidak ditemukan.
                    </p>

                </section>

            </div>

        </b:if>

    </div>

</main>

    <!-- =====================================================
         Footer
    ====================================================== -->

    <footer class='ks-footer'>

        <div class='ks-container ks-footer-container'>

            <div class='ks-footer-brand'>

                <h2 class='ks-footer-title'>
                    KeiScanlation
                </h2>

                <p class='ks-footer-description'>
                    Terjemahan Light Novel Indonesia.
                </p>

            </div>

            <nav class='ks-footer-nav'>

                <a class='ks-footer-link' href='#'>Privacy</a>
                <a class='ks-footer-link' href='#'>Disclaimer</a>
                <a class='ks-footer-link' href='#'>DMCA</a>
                <a class='ks-footer-link' href='#'>Contact</a>

            </nav>

            <p class='ks-footer-copy'>
                © 2026 KeiScanlation. All Rights Reserved.
            </p>

        </div>

    </footer>

</div>

{{KS_JS}}

</body>

</html>